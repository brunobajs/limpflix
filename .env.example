VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Chave PÚBLICA do Mercado Pago (segura no frontend)
VITE_MERCADO_PAGO_PUBLIC_KEY=your-mercadopago-public-key

# IMPORTANTE: O Access Token do Mercado Pago (MERCADO_PAGO_ACCESS_TOKEN) deve ser
# configurado SOMENTE nas Edge Functions do Supabase (Dashboard > Edge Functions > Settings).
# NUNCA coloque o Access Token neste arquivo .env, pois variáveis VITE_ são expostas no navegador.
